<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/imgTape"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:scaleType="fitCenter"
        android:src="@drawable/saved_video"
        android:translationZ="2dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginBottom="-10dp" />

    <View
        android:id="@+id/titleLimitBox"
        android:layout_width="100dp"
        android:layout_height="80dp"

        android:background="@android:color/transparent"
        tools:background="#80FF0000"

        android:translationZ="3dp"
        app:layout_constraintBottom_toBottomOf="@id/imgTape"
        app:layout_constraintEnd_toEndOf="@id/imgTape"
        app:layout_constraintStart_toStartOf="@id/imgTape"
        app:layout_constraintTop_toTopOf="@id/imgTape"
        app:layout_constraintVertical_bias="0.65"
        app:layout_constraintHorizontal_bias="0.475" />
    <TextView
        android:id="@+id/txtTapeTitle"
        android:layout_width="93dp"
        android:layout_height="76dp"
        android:text="제목이길어지면점점점"

        android:gravity="center"
        android:textColor="#333333"
        android:textSize="14sp"
        android:textStyle="bold"
        android:rotation="-2"

        android:maxLines="2"
        android:ellipsize="end"

        android:translationZ="3dp"
        app:layout_constraintBottom_toBottomOf="@id/titleLimitBox"
        app:layout_constraintEnd_toEndOf="@id/titleLimitBox"
        app:layout_constraintStart_toStartOf="@id/titleLimitBox"
        app:layout_constraintTop_toTopOf="@id/titleLimitBox" />
    <View
        android:id="@+id/shelfLine"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:background="@drawable/shelf_line"
        app:layout_constraintTop_toBottomOf="@id/imgTape"
        android:layout_marginTop="-5dp" />

</androidx.constraintlayout.widget.ConstraintLayout>