<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFEBE9"
    android:padding="20dp"
    android:id="@+id/rootLayout">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_back_arrow"
        app:tint="#5D4037"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardPreview"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <ImageView
            android:id="@+id/imgSavePreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/saved_video"
            android:scaleType="centerCrop"
            android:background="#DDDDDD" />
    </androidx.cardview.widget.CardView>

    <EditText
        android:id="@+id/etTitle"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="15dp"
        android:background="@drawable/edittext_bg"
        android:hint="제목을 입력하세요"
        android:paddingHorizontal="15dp"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/cardPreview" />

    <EditText
        android:id="@+id/etLocation"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/edittext_bg"
        android:drawableStart="@android:drawable/ic_menu_mylocation"
        android:drawablePadding="10dp"
        android:hint="위치 (예: 서울시 마포구)"
        android:paddingHorizontal="15dp"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/etTitle" />

    <LinearLayout
        android:id="@+id/layoutEmotions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/etLocation">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLove"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:background="@drawable/bg_rounded_dialog"
            android:backgroundTint="#D7A2A2"
            android:text="사랑해"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginEnd="8dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnThanks"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:background="@drawable/bg_rounded_dialog"
            android:backgroundTint="#9FA88F"
            android:text="고마워"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginEnd="8dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSorry"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:background="@drawable/bg_rounded_dialog"
            android:backgroundTint="#90A4AE"
            android:text="미안해"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>
    </LinearLayout>

    <EditText
        android:id="@+id/etDescription"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/edittext_bg"
        android:gravity="top|start"
        android:hint="짧은 기록 남기기..."
        android:padding="15dp"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@id/btnSave"
        app:layout_constraintTop_toBottomOf="@id/layoutEmotions" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@drawable/button_bg"
        android:text="기록 저장하기"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>