<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/guideImage"
        android:layout_width="579dp"
        android:layout_height="921dp"
        android:adjustViewBounds="true"
        android:contentDescription="카메라 사용 방법 가이드"
        android:src="@drawable/guide_screenshot"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.336" />

    <View
        android:id="@+id/btnGuideClose"
        android:layout_width="24dp"
        android:layout_height="31dp"
        android:layout_marginStart="96dp"
        android:layout_marginTop="148dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:contentDescription="가이드 닫기"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="@+id/guideImage"
        app:layout_constraintTop_toTopOf="@+id/guideImage" />

    <View
        android:id="@+id/btnGuideConfirm"
        android:layout_width="134dp"
        android:layout_height="65dp"
        android:layout_marginBottom="264dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:contentDescription="확인 및 카메라 시작"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="@+id/guideImage"
        app:layout_constraintEnd_toEndOf="@+id/guideImage"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="@+id/guideImage" />
</androidx.constraintlayout.widget.ConstraintLayout>