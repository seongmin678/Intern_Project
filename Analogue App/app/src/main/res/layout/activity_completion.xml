<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/rootLayout">

    <ImageView
        android:id="@+id/blurBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/blur_background" />

    <ImageView
        android:id="@+id/btnBackArrow"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="20dp"
        android:src="@drawable/ic_rewind"
        android:clickable="true"
        android:focusable="true"
        android:elevation="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#99F2EFE5"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.4">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/windowControls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginStart="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <View android:id="@+id/btnGoHome"
                    android:layout_width="12dp" android:layout_height="12dp"
                    android:background="@drawable/circle_dot" android:backgroundTint="#FF6B6B"
                    android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>

                <View android:layout_width="12dp" android:layout_height="12dp"
                    android:background="@drawable/circle_dot" android:backgroundTint="#FFD93D"
                    android:layout_marginEnd="8dp"/>

                <View android:layout_width="12dp" android:layout_height="12dp"
                    android:background="@drawable/circle_dot" android:backgroundTint="#6BCB77"/>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/tapeContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                app:layout_constraintTop_toBottomOf="@id/windowControls"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:src="@drawable/saved_video" />

                <TextView
                    android:id="@+id/txtVideoTitle"
                    android:layout_width="80dp"
                    android:layout_height="65dp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-condensed"
                    android:maxLines="3"
                    android:padding="4dp"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="7dp"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="10dp"
                    />
            </FrameLayout>

            <TextView
                android:id="@+id/txtFinalStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="완성!"
                android:textSize="48sp"
                android:textColor="#3E3E3E"
                android:fontFamily="@font/nanum_brush_script"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="50dp"
                app:layout_constraintTop_toBottomOf="@id/tapeContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>