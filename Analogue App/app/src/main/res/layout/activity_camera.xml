<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A6A6A6">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="7dp"
        android:layout_marginTop="25dp"
        android:padding="10dp"
        android:src="@drawable/ic_back_arrow"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="뒤로가기"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="10dp"/>

    <FrameLayout
        android:id="@+id/cameraFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:background="#1A1A1A"
        android:padding="10dp"
        app:layout_constraintDimensionRatio="3:4"
        app:layout_constraintBottom_toTopOf="@+id/imgController"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnBack">

        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter" />

        <ImageView
            android:id="@+id/imgPhotoReview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:background="#000000"
            android:visibility="gone" />

        <TextView
            android:id="@+id/txtTimeStamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="12dp"
            android:textColor="#FF9800"
            android:textSize="14sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="2"
            android:fontFamily="monospace" />
    </FrameLayout>

    <ImageView
        android:id="@+id/imgController"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="20dp"
        android:adjustViewBounds="true"
        android:src="@drawable/camera_controller_full"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cameraFrame"
        app:layout_constraintVertical_bias="1.0" />

    <View
        android:id="@+id/btnCapture"
        android:layout_width="86dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="@+id/imgController"
        app:layout_constraintTop_toTopOf="@+id/imgController"
        app:layout_constraintStart_toStartOf="@+id/imgController"
        app:layout_constraintEnd_toEndOf="@+id/imgController"
        app:layout_constraintVertical_bias="0.85"
        app:layout_constraintHorizontal_bias="0.902" />

    <View
        android:id="@+id/btnRecord"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="@+id/imgController"
        app:layout_constraintTop_toTopOf="@+id/imgController"
        app:layout_constraintStart_toStartOf="@+id/imgController"
        app:layout_constraintEnd_toEndOf="@+id/imgController"
        app:layout_constraintVertical_bias="0.05"
        app:layout_constraintHorizontal_bias="0.946" />



    <ImageView
        android:id="@+id/btnConfirm"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_check"
        app:tint="#4CAF50"
        android:background="@drawable/circle_white_bg"
        android:padding="10dp"
        android:visibility="gone"
        android:elevation="100dp"
        app:layout_constraintBottom_toBottomOf="@+id/btnCapture"
        app:layout_constraintTop_toTopOf="@+id/btnCapture"
        app:layout_constraintStart_toStartOf="@+id/btnCapture"
        app:layout_constraintEnd_toEndOf="@+id/btnCapture" />

    <View android:id="@+id/flashView" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FFFFFF" android:visibility="gone" android:elevation="100dp" />

    <View
        android:id="@+id/btnRetry"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        tools:visibility="visible"
        android:elevation="100dp"
        app:layout_constraintBottom_toBottomOf="@+id/imgController"
        app:layout_constraintTop_toTopOf="@+id/imgController"
        app:layout_constraintStart_toStartOf="@+id/imgController"
        app:layout_constraintEnd_toEndOf="@+id/imgController"
        app:layout_constraintHorizontal_bias="0.02"
        app:layout_constraintVertical_bias="0.75" />

    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/recordingOverlay" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#D9000000" android:visibility="gone" android:elevation="100dp">
        <View android:id="@+id/btnRecordExit" android:layout_width="24dp" android:layout_height="24dp" android:layout_margin="30dp" android:background="@drawable/circle_dot" android:backgroundTint="#FF4B4B" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
        <TextView android:id="@+id/txtOverlayTimer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="60dp" android:fontFamily="monospace" android:text="00:00.00" android:textColor="#FFFFFF" android:textSize="40sp" android:textStyle="bold" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
        <com.dodam.analogueapp.HorizontalRecorderView android:id="@+id/overlayRecorderView" android:layout_width="match_parent" android:layout_height="0dp" android:rotation="-90" app:layout_constraintBottom_toTopOf="@+id/btnStopRecordCircle" app:layout_constraintTop_toBottomOf="@id/txtOverlayTimer" />
        <FrameLayout android:id="@+id/btnStopRecordCircle" android:layout_width="90dp" android:layout_height="90dp" android:layout_marginBottom="50dp" android:background="@drawable/bg_shutter_button" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"> <View android:layout_width="30dp" android:layout_height="30dp" android:layout_gravity="center" android:background="#FF4B4B" /> </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>